# Copy this file to .env.local for local development. Do not commit .env.local.
# Find the project URL in Supabase: Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# This is the browser-safe publishable/anonymous key, not an sb_secret key.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
